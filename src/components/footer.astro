---
const year = () => new Date().getFullYear();
const wn = "WQON";
---

<!-- CSS -->
<style>
footer {
    background: var(--bg);
    color: var(--08);
    line-height: 1;
    padding: 2rem 3rem;
    margin: 0;
}
footer p {
    padding: 0;
    margin: 0;
}

.footer-wrapper {
    display: flex;
    flex-direction: row;
    width: 100%;
}
.footer-left {
    display: flex;
    flex: 1;
    justify-content: left;
    align-items: start;
    text-align: left;
}
.footer-right {
    display: flex;
    flex: 1;
    justify-content: right;
    align-items: start;
    text-align: right;
}
</style>

<!-- HTML -->
<hr />
<footer class="medium">
    <div class="footer-wrapper">
        <div class="footer-left">
            <span class="normal">
                © {year()}
                {wn}. All Rights Reserved.<br />
                <span class="x-small">
                Website designed & developed by Lukáš "{wn}" Nox.
                </span>
            </span>
        </div>
        <div class="footer-right">
            <p>
                <span> Socials.</span>
                <br />
                <span class="small">
                    <a href="/links">Links</a> -
                    <a href="">Legal Notice</a>
                </span>
            </p>
        </div>
    </div>
</footer>
<!-- Designed & developed by Lukáš "WQON" Nox! -->
