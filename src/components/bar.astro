<!-- CSS -->
<style>
@keyframes scroll {
    from {
        transform: translateX(0);
    }
    to {
        transform: translateX(-50%);
    }
}
.bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--bar-gap);
    padding: 0;
    margin: 0;
    z-index: 98;
}
.bar-scroll {
    top: 0;
    bottom: 0;
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
    box-sizing: border-box;
    mask-image: linear-gradient(to right, transparent, black 16%, black 84%, transparent);
    mask-size: 100%;
}
.bar-scroll .inner {
    display: inline-flex;
    white-space: nowrap;
    animation: scroll 36s linear infinite;
    will-change: transform;
}
.bar-scroll .inner span {
    line-height: 48px;
    margin-left: var(--site-gap);
    transition: color 0.6s ease;
}
.bar-scroll .inner:hover {
    animation-play-state: paused;
    color: var(--wnt-blue);
    cursor: pointer;
}
.bar-scroll .inner:active {
    color: var(--yellow);
}
</style>

<!-- HTML -->
