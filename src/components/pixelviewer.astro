<!-- CSS -->
<style>
    .pixelviewer {
        display: block;
        position: fixed;
        top: calc(96px + 2px + var(--bar-gap));
        bottom: calc(64px + 1px);
        left: 0;
        right: 0;
        padding: 0;
        margin: 0;
    }
    .pv-wrapper {
        display: grid;
        grid-template-rows: 1fr 192px;
        grid-template-columns: 1fr;
        height: 100%;
        width: 100%;
    }
    .pv-artarea {
        height: 100%;
        width: 100%;
        border-bottom: solid 1px var(--08);
    }
    .pv-artarea-wrapper {
        display: grid;
        grid-template-columns: calc(36% + 1px) auto;
        grid-template-rows: 1fr;
        height: 100%;
        width: 100%;
    }
    .pv-metadata {
        height: 100%;
        width: 100%;
        border-right: solid 1px var(--08);
    }
    .pv-art {
        height: 100%;
        width: 100%;
    }
    .pv-switcher {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-content: center;
        height: 100%;
        width: 100%;
    }
    .pv-left {
        display: flex;
        flex: 1;
        justify-items: left;
        max-width: 96px;
        border-right: solid 1px var(--08);
    }
    .pv-works {
        display: flex;
        flex: 1;
        width: 96px;
        border-right: solid 1px var(--08);
    }
    .pv-right {
        display: flex;
        flex: 1;
        justify-items: right;
        max-width: 96px;
    }
</style>

<!-- HTML -->
<section>
    <div class="pv-slideshow">
        <div class="pixelviewer">
            <div class="pv-wrapper">
                <div class="pv-artarea">
                    <div class="pv-artarea-wrapper">
                        <div class="pv-metadata"></div>
                        <div class="pv-art"></div>
                    </div>
                </div>
                <div class="pv-switcher">
                    <div class="pv-left">--</div>
                    <div class="pv-works"></div>
                    <div class="pv-right">--</div>
                </div>
            </div>
        </div>
    </div>
    <div class="pv-grid"></div>
</section>
