<!-- CSS -->
<style>
    header {
        position: fixed;
        top: var(--bar-gap);
        left: 0;
        right: 0;
        height: 48px;
        backdrop-filter: blur(0.5);
        z-index: 99;
    }
    .header-wrapper {
        display: flex;
        flex-direction: row;
        width: 100%;
        border-top: solid 1px var(--08);
        border-bottom: solid 1px var(--08);
    }
    .header-left {
        display: flex;
        flex: auto;
        justify-content: left;
        align-items: center;
        max-width: 36%;
        padding-left: var(--site-gap);
    }
    .header-right {
        display: flex;
        flex: auto;
        justify-content: right;
        align-items: center;
        text-align: center;
    }
    .header-right a,
    .plus {
        display: flex;
        flex: 1;
        justify-content: center;
        align-items: center;
        text-align: center;
        height: 96px;
        color: var(--08);
        font-size: var(--medium);
        border-left: solid 1px var(--08);
        transition: all 1s ease;
    }
    .header-right a:hover,
    .plus:hover {
        background: var(--yellow);
    }
    .header-right a:active,
    .plus:active {
        background: var(--fc);
    }
    label.plus::after {
        content: "+";
    }
    .plus {
        cursor: pointer;
    }
    .plus.wrapper {
        max-width: 96px;
        border: none;
    }
    #plus-toggle {
        display: none;
    }
    #plus-toggle:checked ~ .plus.wrapper {
        max-width: 192px !important;
    }
    #plus-toggle:checked ~ .plus-content {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateX(0);
        transition:
            transform 0.6s ease,
            opacity 0.6s ease,
            visibility 0s 0s;
    }
    #plus-toggle:checked ~ .plus::after {
        content: "×";
    }
    .plus-content {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateX(100%);
        display: flex;
        flex-direction: column;
        position: fixed;
        top: calc(96px + 2px + var(--bar-gap));
        right: 0;
        bottom: 64px;
        width: 192px;
        background: var(--bg);
        border-left: solid 1px var(--08);
        transition:
            transform 0.6s ease,
            opacity 0.6s ease,
            visibility 0s 0.6s;
    }
    .plus-content a {
        border: none;
        border-bottom: solid 1px var(--08);
    }

    img#logo {
        max-height: 64px;
        width: auto;
    }
</style>

<!-- HTML -->
<header draggable="false">
    <div class="header-wrapper">
        <div class="header-left">
            <img
                src="/assets/logo-white.png"
                id="logo"
                alt="WQON — Pixel Dracologist"
            />
        </div>
        <nav class="header-right">
            <a href="/" class="art">Art</a>
            <a href="/fonts" class="fonts">Fonts</a>
            <a href="/commissions" class="hire-me">Hire Me</a>
            <a href="/about" class="about">About</a>
            <div class="plus wrapper">
                <input type="checkbox" id="plus-toggle" />
                <label for="plus-toggle" class="plus"></label>
                <div class="plus-content">
                    <a href="/shop" class="shop">Art Shop</a>
                    <a href="/shop" class="shop">Support 🖤</a>
                </div>
            </div>
        </nav>
    </div>
</header>
